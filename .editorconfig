; EditorConfig is awesome: http://EditorConfig.org

; top-most EditorConfig file
root = true

; Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[{.babelrc,.stylelintrc,jest.config,.eslintrc,*.bowerrc,*.jsb3,*.jsb2,*.json}]
indent_style=space
indent_size=2

[{jshint.json,*.jshintrc}]
indent_style=space
indent_size=2

[{*.ddl,*.sql}]
indent_style=space
indent_size=2

[{*.scala,*.sc}]
indent_style=space
indent_size=2

[*.sbt]
indent_style=space
indent_size=2

[*.conf]
indent_style=space
indent_size=2

[*.less]
indent_style=space
indent_size=2

[{*.yml,*.yaml}]
indent_style=space
indent_size=2